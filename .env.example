# Copy this file to .env and fill in your values.
# NEVER commit .env — it holds your AGH app password. (.gitignore already excludes it.)

# ── Required for local use ───────────────────────────────────────────────────

# Your full AGH student email address
AGH_EMAIL=your_id@student.agh.edu.pl

# Application password generated in the AGH Webmail panel
# (NOT your regular SSO password — see the README, Step 1)
AGH_APP_PASS=your_app_password_here

# ── Optional (only for future network/cloud hosting — not needed locally) ────

# Shared secret to gate the server when exposed over the network.
# Unused in local stdio mode; leave commented out.
# MCP_TOKEN=replace_with_random_hex_string

# Transport mode: "stdio" for local (default), "sse" for cloud.
# MCP_TRANSPORT=stdio
